[Unit]
Description=Deine Mutter Queue Worker
Wants=network-online.target docker.service
After=network-online.target docker.service

[Service]
User=admin
Group=admin
WorkingDirectory=/var/www/deine-mutter
ExecStartPre=/bin/bash -lc 'for i in {1..60}; do (echo > /dev/tcp/127.0.0.1/5432) >/dev/null 2>&1 && exit 0; sleep 2; done; echo "Postgres did not become reachable on 127.0.0.1:5432" >&2; exit 1'
ExecStart=/usr/bin/php artisan queue:work --tries=3 --timeout=60
Restart=always
RestartSec=3
EnvironmentFile=/var/www/deine-mutter/.env

[Install]
WantedBy=multi-user.target
